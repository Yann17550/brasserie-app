# .gitignore

# Clés secrètes et variables d'environnement (À NE JAMAIS PUSH)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Dépendances (les dossiers générés automatiquement, trop lourds pour Git)
node_modules/
/dist
/build

# Fichiers système ou de configuration d'éditeurs
.DS_Store
.vscode/
.idea/
npm-debug.log*
yarn-debug.log*
yarn-error.log*